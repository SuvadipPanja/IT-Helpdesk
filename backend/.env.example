# Server Configuration
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
APP_PUBLIC_URL=http://localhost:5173

# Database Configuration
# SECURITY: Use a dedicated DB user instead of 'sa' — see scripts/create-db-user.sql
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=ITHelpdesk
DB_USER=helpdesk_app
DB_PASSWORD=<GENERATE_STRONG_PASSWORD>
DB_PORT=1433
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# JWT Configuration
# Generate a strong JWT secret:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRE=8h
JWT_REFRESH_EXPIRE=7d

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.pdf,.doc,.docx,.xls,.xlsx,.txt,.zip

# Security Configuration
BCRYPT_ROUNDS=12

# Behind nginx/IIS/load balancer: trust X-Forwarded-For (true, or number of proxy hops)
TRUST_PROXY=1

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Logging Configuration
LOG_LEVEL=DEBUG
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true

# License Configuration
# Paste the public key generated by D:\Project\it-helpdesk\license-generator
# Replace line breaks with \n when storing in .env
LICENSE_PUBLIC_KEY=

# Secret required for the public /license-recovery page
LICENSE_RECOVERY_KEY=

# Optional stable salt used in server fingerprint generation
LICENSE_INSTANCE_SALT=

# Optional stable fingerprint seed for Docker/container deployments.
# When set, fingerprint binding no longer depends on container hostname.
LICENSE_FINGERPRINT_SEED=

# Optional clock rollback tolerance in milliseconds (default 10 minutes)
LICENSE_CLOCK_ROLLBACK_TOLERANCE_MS=600000

# Local Ollama endpoint (Docker example: http://ollama:11434)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# FEATURE FLAGS
# Set to 'true' to enable, 'false' to disable (or omit = true)
# ============================================================
# PR-4: Guided intake forms with category-specific sections
FEATURE_GUIDED_INTAKE=true

# PR-5: Incident/maintenance announcement banners
FEATURE_INCIDENT_BANNER=true

# PR-6: Bulk ticket operations (close, assign, export selected)
FEATURE_BULK_TICKET_ACTIONS=true

# PR-6: Engineer response snippets / canned responses
FEATURE_SNIPPETS=true

# PR-7: Skill-based auto-assignment via assignment rules
FEATURE_AUTO_ASSIGN_V2=true

# PR-7: In-ticket AI assist panel for engineers (summarize / draft / next action)
FEATURE_ENGINEER_AI_ASSIST=true

# ============================================================
# EMAIL (SMTP) — optional, enables email notifications
# ============================================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=notifications@example.com
# SMTP_PASS=change-me
# EMAIL_FROM="IT Helpdesk <noreply@example.com>"

# ============================================================
# SESSION / RATE LIMITING
# ============================================================
# Max login attempts before temporary account lock
# MAX_LOGIN_ATTEMPTS=5
# Lockout duration in minutes
# LOCKOUT_DURATION_MINUTES=15
